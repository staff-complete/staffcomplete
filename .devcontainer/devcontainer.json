{
  "name": "staffcomplete",
  "build": {
    "dockerfile": "Dockerfile"
  },
"workspaceFolder": "/workspaces/staffcomplete",
  "postCreateCommand": "pnpm install",
  "customizations": {
    "vscode": {
      "settings": {
        "github.copilot.chat.welcomeMessage": "never",
        "github.copilot.chat.startDebuggingFlow.enabled": false,
        "github.copilot.chat.runCommand.enabled": false,
        "github.copilot.chat.setupTests.enabled": false,
        "github.copilot.chat.fixTestFailure.enabled": false,
        "github.copilot.chat.edits.enabled": false,
        "github.copilot.chat.agent.thinkingTool": false,
        "chat.commandCenter.enabled": false,
        "workbench.activityBar.hidden": false,
        "github.copilot.chat.generateCommitMessage.enabled": true,
        "github.copilot.editor.enableAutoCompletions": true,
        "editor.fontFamily": "'JetBrains Mono', Consolas, 'Courier New', monospace",
        "editor.fontSize": 13,
        "editor.fontLigatures": true,
        "editor.letterSpacing": 0.4,
        "editor.smoothScrolling": true,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.oxlint": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        },
        "[json]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "explorer.fileNesting.enabled": true,
        "explorer.fileNesting.patterns": {
          "tsconfig.json": "tsconfig.*.json, env.d.ts",
          "vite.config.*": "vitest.config.*",
          "package.json": "pnpm-lock.yaml, .oxlint*, .oxfmt*, .commitlint*, .lintstagedrc, cspell.json, .editorconfig, .markdownlint.json"
        }
      },
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "codacy-app.codacy",
        "oxc.oxc-vscode",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/dev/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.zsh_history,target=/home/dev/.zsh_history,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/dev/.claude,type=bind,consistency=cached"
  ],
  "remoteUser": "dev",
  "remoteEnv": {
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "GIT_CONFIG_COUNT": "2",
    "GIT_CONFIG_KEY_0": "gpg.format",
    "GIT_CONFIG_VALUE_0": "ssh",
    "GIT_CONFIG_KEY_1": "user.signingkey",
    "GIT_CONFIG_VALUE_1": "/home/dev/.ssh/id_rsa.pub"
  }
}
