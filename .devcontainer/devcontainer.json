{
  "name": "staffcomplete",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/staffcomplete",
  "postCreateCommand": "pnpm install && ([ -f .env ] || cp .env.example .env)",
  "customizations": {
    "vscode": {
      "settings": {
        "github.copilot.chat.welcomeMessage": "never",
        "github.copilot.chat.startDebuggingFlow.enabled": false,
        "github.copilot.chat.runCommand.enabled": false,
        "github.copilot.chat.setupTests.enabled": false,
        "github.copilot.chat.fixTestFailure.enabled": false,
        "github.copilot.chat.edits.enabled": false,
        "github.copilot.chat.agent.thinkingTool": false,
        "chat.commandCenter.enabled": false,
        "workbench.activityBar.hidden": false,
        "github.copilot.chat.generateCommitMessage.enabled": true,
        "github.copilot.editor.enableAutoCompletions": true,
        "editor.fontFamily": "'JetBrains Mono', Consolas, 'Courier New', monospace",
        "editor.fontSize": 13,
        "editor.fontLigatures": true,
        "editor.letterSpacing": 0.4,
        "editor.smoothScrolling": true,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.oxlint": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        },
        "[json]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "explorer.fileNesting.enabled": true,
        "explorer.fileNesting.patterns": {
          "tsconfig.json": "tsconfig.*.json, env.d.ts",
          "vite.config.*": "vitest.config.*",
          "package.json": "pnpm-lock.yaml, .oxlint*, .oxfmt*, .commitlint*, .lintstagedrc, cspell.json, .editorconfig, .markdownlint.json, .releaserc.json"
        }
      },
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "codacy-app.codacy",
        "oxc.oxc-vscode",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },
  "forwardPorts": [3000, 5173, 5432],
  "portsAttributes": {
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "dev"
}
