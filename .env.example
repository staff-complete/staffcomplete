# Registry — use a GitHub PAT with packages:read/write scope (or GITHUB_TOKEN in CI)
KAMAL_REGISTRY_PASSWORD=

# PostgreSQL accessory password (Kamal sets POSTGRES_PASSWORD on the db container)
POSTGRES_PASSWORD=

# Full connection string — in devcontainer the db service shares the app's network (localhost)
DATABASE_URL=postgresql://staffcomplete:staffcomplete@localhost:5432/staffcomplete

# Password for the restricted, RLS-enforced Postgres role (staffcomplete_app)
# used for tenant-scoped queries — see ADR-0012. Generate with: openssl rand -hex 32
APP_DB_PASSWORD=

# Connection string for tenant-scoped queries, authenticated as
# staffcomplete_app instead of the superuser role. Same password as
# APP_DB_PASSWORD above.
APP_DATABASE_URL=postgresql://staffcomplete_app:staffcomplete_app@localhost:5432/staffcomplete

# Better Auth secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Better Auth base URL — the API origin (used in email verification links)
BETTER_AUTH_URL=http://localhost:3000

# Frontend URL — trusted for CORS and redirects
APP_URL=http://localhost:5173

# Resend API key for transactional email
RESEND_API_KEY=
