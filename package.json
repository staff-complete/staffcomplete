{
  "name": "staffcomplete",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "lint": "oxlint .",
    "format": "oxfmt --ignore-path .oxfmtignore --ignore-path .gitignore .",
    "format:check": "oxfmt --check --ignore-path .oxfmtignore --ignore-path .gitignore .",
    "cspell": "cspell \"**\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "turbo": "^2.10.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0"
}
